# Copy to .env.production and fill in. Injected into the app at RUNTIME.

# ── Database (compose service name "db") ──
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=code_review
DATABASE_URL=postgresql://postgres:change-me-strong@db:5432/code_review?schema=public

# ── Auth.js ──
# openssl rand -base64 32
AUTH_SECRET=change-me
# Public HTTPS URL users reach the app at (must match the GitHub App callback host).
AUTH_URL=https://codereview.corp.example.com
AUTH_TRUST_HOST=true

# ── GitHub Enterprise (GHES) App — user-to-server OAuth ──
GITHUB_CLIENT_ID=Iv1.xxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
# GHES web host (OAuth authorize/token endpoints):
GITHUB_BASE_URL=https://github.corp.example.com
# GHES REST API base:
GITHUB_API_URL=https://github.corp.example.com/api/v3
# 32-byte key (base64) to encrypt GitHub tokens at rest. openssl rand -base64 32
TOKEN_ENC_KEY=change-me-32-bytes-base64

# ── Internal LLM (OpenAI-compatible: LiteLLM / vLLM on-prem) ──
LLM_BASE_URL=http://litellm.corp.example.com:4000/v1
LLM_API_KEY=internal-virtual-key
LLM_MODELS=qwen2.5-coder-32b-instruct,llama-3.3-70b-instruct
LLM_DEFAULT_MODEL=qwen2.5-coder-32b-instruct
LLM_MAX_CONTEXT=16000

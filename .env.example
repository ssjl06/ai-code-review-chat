# ──────────────────────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/code_review?schema=public"

# ──────────────────────────────────────────────────────────────
# Auth.js
# ──────────────────────────────────────────────────────────────
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="change-me"
# Public origin of this app (used for OAuth callback). No trailing slash.
AUTH_URL="http://localhost:3000"

# ──────────────────────────────────────────────────────────────
# GitHub (Enterprise) App — OAuth (user-to-server) credentials
# Works for github.com too: set the URLs to https://github.com / https://api.github.com
# ──────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID="Iv1.xxxxxxxxxxxx"
GITHUB_CLIENT_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Web host of the GitHub Enterprise instance (used for OAuth authorize/token endpoints).
GITHUB_BASE_URL="https://github.example.com"
# REST API base of the GitHub Enterprise instance.
# GHES: https://github.example.com/api/v3   |   github.com: https://api.github.com
GITHUB_API_URL="https://github.example.com/api/v3"

# 32-byte key (base64) used to AES-256-GCM encrypt GitHub tokens at rest.
# Generate with: openssl rand -base64 32
TOKEN_ENC_KEY="change-me-32-bytes-base64"

# ──────────────────────────────────────────────────────────────
# LLM — OpenAI-compatible endpoint (LiteLLM / vLLM)
# ──────────────────────────────────────────────────────────────
LLM_BASE_URL="http://localhost:4000/v1"
LLM_API_KEY="sk-litellm-virtual-key"
# Comma-separated list of model ids surfaced in the UI dropdown.
LLM_MODELS="qwen2.5-coder-32b-instruct,llama-3.3-70b-instruct"
LLM_DEFAULT_MODEL="qwen2.5-coder-32b-instruct"
# Approx max prompt tokens to budget for context assembly.
LLM_MAX_CONTEXT="16000"

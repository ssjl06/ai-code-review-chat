Bootstrap: docker
From: node:20-slim

# "Environment" image: Node 20 + this project's node_modules + generated Prisma
# client/engine + build toolchain (npm, next, prisma CLI). It does NOT contain
# the app source or the .next build — those live on the host and are bind-mounted
# over /app at runtime. Rebuild this SIF only when dependencies change.
#
#   build:    apptainer run --app build   --bind <src> ... env.sif   (next build → host .next)
#   migrate:  apptainer run --app migrate --bind <src> ... env.sif
#   serve:    apptainer run               --bind <src> ... env.sif   (next start)
# See run-app-src.sh for the exact bind set.

%files
    package.json /app/package.json
    package-lock.json /app/package-lock.json
    prisma /app/prisma

%post
    set -eux
    export NEXT_TELEMETRY_DISABLED=1
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends openssl ca-certificates
    rm -rf /var/lib/apt/lists/*

    cd /app
    npm ci --legacy-peer-deps
    npx prisma generate
    npm cache clean --force >/dev/null 2>&1 || true
    mkdir -p /app/.next
    chmod -R a+rX /app

%environment
    export NODE_ENV=production
    export NEXT_TELEMETRY_DISABLED=1

# Serve the already-built app (host source bound over /app, .next bound writable).
%runscript
    cd /app
    exec node_modules/.bin/next start -H 0.0.0.0 -p "${PORT:-3000}"

# Rebuild .next from the (bound) host source using the in-SIF node_modules.
%apprun build
    cd /app
    exec npm run build

# Apply DB migrations using the in-SIF Prisma CLI and the (bound) host schema.
%apprun migrate
    cd /app
    exec node_modules/.bin/prisma migrate deploy --schema /app/prisma/schema.prisma

%help
    Environment image (Node + deps + toolchain). The app source lives on the host
    and is bound over /app at runtime; code changes need only `next build`, not a
    SIF rebuild. Rebuild this SIF only when package.json/lock changes.

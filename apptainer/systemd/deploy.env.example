# Deployment paths/ports read by the systemd units (NOT the app's runtime env).
# Installed to /etc/codereview/deploy.env (system) or ~/.config/codereview/deploy.env (user).

# SIF image locations
PG_SIF=/opt/codereview/postgres.sif
APP_SIF=/opt/codereview/codereview.sif

# Postgres data directory — the only large/growing dir. Put on a big disk or NFS.
PGDATA_HOST=/srv/codereview/pgdata
PGPORT=5432
PG_LISTEN=localhost

# The app's runtime env file (GITHUB_*, LLM_*, DATABASE_URL, AUTH_*, TOKEN_ENC_KEY,
# PORT, HOSTNAME). DATABASE_URL must use the PGPORT above, e.g.:
#   postgresql://postgres:<pw>@localhost:5432/code_review?schema=public
ENV_FILE=/etc/codereview/.env.production
